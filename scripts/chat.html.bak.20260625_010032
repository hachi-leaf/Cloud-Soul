<button class="toggle" onclick="td()" title="切换深色模式" id="darkBtn">🌙</button>
<div class="msgs" id="ms"><div class="msgs-inner" id="mi"><div class="empty-hint"><div class="logo">🤖</div><div>开始对话吧</div></div></div></div>
<div class="bottom">
  <div class="bottom-inner">
    <div class="up-bar" id="ub"></div>
    <div class="inp-bar">
      <textarea id="ti" rows="2" placeholder="输入消息... (Enter 发送, Alt+Enter 换行)"></textarea>
      <button class="btn" id="fb" title="上传文件">＋</button>
      <button class="btn send-btn" id="sb" title="发送" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
    <div id="st">就绪</div>
  </div>
